{
  "expo": {
    "name": "Orbitracker",
    "slug": "orbistorewid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "macrotrack",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "minSdkVersion": 24,
      "ndkVersion": "30.0.15729638",
      "softwareKeyboardLayoutMode": "resize",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "whatsapp"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground2.png",
        "backgroundImage": "./assets/images/Orange.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "macrot.cm"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "OrbitrackerWidget",
              "label": "Quick Actions",
              "minWidth": "100dp",
              "minHeight": "50dp",
              "targetCellWidth": 2,
              "targetCellHeight": 1,
              "description": "search and add entries",
              "updatePeriodMillis": 86400000,
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon1.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "88dcc44b-49bf-48da-aa41-f45bb342d03a"
      }
    },
    "owner": "seencodes"
  }
}